---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Productos y Soluciones SaaS | DinamyCode"
  description="Conoce nuestras soluciones SaaS diseñadas para resolver problemas reales en Colombia. 🛠️ Desde Asambli (gestión de asambleas PH), hasta Lisapp (laboratorio clínico inteligente) y FotoAleph (eventos y fotografía profesional). Software de alta calidad."
>



  <section class="productos-section">
    <div class="container">
      <h1>Nuestros Productos</h1>
      <p class="subtitle">Soluciones tecnológicas desarrolladas para optimizar tu negocio</p>
     
      <div class="willing-grid">
        <div class="willing-card bg-blue-400">
          <h3>Asambli</h3>
          <p>Gestión de Asambleas de propiedad horizontal</p>
        </div>

        <div class="willing-card bg-cyan-800">
          <div>       
             <a href="https://lissapp.dinamycode.com/" target="_blank" class="btn btn-primary bg-cyan-300 hover:bg-cyan-50 p-2 rounded-md"> <span class="text-3xl">🔬</span>Lissapp</a>
          </div>
          <div>
          <h3>Lissapp</h3>
          <p>Tu aliado en la gestión de tu laboratorio clínico</p>
          </div>

        </div>

      </div>

      <div class="productos-grid">

        <div class="producto-card">
          <h3>Sitios Web</h3>
          <p>Diseño web moderno, responsivo y optimizado para SEO</p>
        </div>
        <div class="producto-card">
          <h3>Aplicaciones Móviles</h3>
          <p>Apps nativas y multiplataforma para iOS y Android</p>
        </div>
        <div class="producto-card">
          <h3>Software a Medida</h3>
          <p>Soluciones empresariales personalizadas para tus necesidades</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .productos-section {
    min-height: 60vh;
    padding: 4rem 2rem;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .subtitle {
    font-size: 1.125rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }
  
  .productos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  .willing-grid {
    display: grid;
    grid-template-columns:auto auto;
    padding: 1rem;
    gap: 1rem;
  }

  .producto-card {
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }
  
  .willing-card {
    padding: 2rem;
    border: 2px solid rgba(255, 255, 255, 0.893);
    border-radius: 0.5rem;
    background-image: url('/img/ads.png');
    transition: all 0.3s ease;
  }
  
  

  .producto-card:hover,
  .willing-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .producto-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
</style>
