---
// Layout component: includes SEO head, fonts, preloader, navbar, footer, and slot for page content
---

---
// Import components
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
---

---
// SEO meta defaults – will be overridden via frontmatter props when needed
export interface Props {
  title?: string;
  description?: string;
  image?: string; // og:image URL
  lang?: string;
}
---

---
const { title = 'DinamyCode – Agencia de diseño web y desarrollo de software',
        description = 'Transformamos negocios con tecnología que convierte visitantes en clientes reales.',
        image = '/og-image.png',
        lang = 'es' } = Astro.props as Props;
---

---
<!DOCTYPE html>
<html lang={lang} class="scroll-smooth bg-ink text-paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <!-- Google Fonts – Inter & Outfit for premium typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet" />
    <!-- Astro prefetch for all internal links – already used in components -->
    <AstroHead />
  </head>
  <body class="antialiased min-h-screen flex flex-col">
    <!-- Preloader (visible until page fully loaded) -->
    <Preloader />
    <!-- Navbar -->
    <Navbar />
    <!-- Main content -->
    <main class="flex-1 pt-24 md:pt-28">
      <slot />
    </main>
    <!-- Footer -->
    <Footer />
    <!-- Global scripts (optional) -->
    <script async defer data-astro-prefetch src="/js/main.js"></script>
  </body>
</html>
