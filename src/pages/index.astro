---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Diseño Web y Desarrollo de Software en Bogotá | DinamyCode"
  description="¿Listo para liderar la era digital? 🚀 DinamyCode diseña el futuro de tu negocio con desarrollo de software a medida, páginas web de alto impacto y soluciones avanzadas de Inteligencia Artificial en Bogotá. ¡Transforma tus ideas en resultados reales hoy!"
>
  <section class="hero">
    <div class="container">
      <h1>Transformamos tu negocio con tecnología</h1>
      <p>Soluciones digitales a medida que convierten visitantes en clientes</p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  h1 {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  
  p {
    font-size: 1.25rem;
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }
</style>
