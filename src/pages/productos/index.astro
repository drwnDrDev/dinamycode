---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Productos y Soluciones SaaS | DinamyCode"
  description="Mobile web development - software Asambleas de Propiedad Horizontal - Gestor de tu laboratorio clínico"
>



  <section class="productos-section">
    <div class="container">
      <h1>Nuestros Productos</h1>
      <p class="subtitle">Soluciones tecnológicas desarrolladas para optimizar tu negocio</p>
     
      <div class="willing-grid">
        <a href="https://asambli.dinamycode.com/" class="willing-card bg-blue-400">
          <h3>Asambli</h3>
          <p>Gestión de Asambleas de propiedad horizontal</p>
          <div class="image p-4">
            <img class="w-88" src="/assets/img/asambli.png" alt="Asambli">
          </div>
        </a>

        <a href="https://lissapp.dinamycode.com/" target="_blank" class="willing-card bg-cyan-800">

         
          <h3> 🔬 Lissapp</h3>
          <p>Tu aliado en la gestión de tu laboratorio clínico</p>
          
          <div  class="image p-4">
              <img class="w-88" src="/assets/img/lissapp.png" alt="Lissapp">
          </div>

        </a>

      </div>

      <div class="productos-grid">

        <div class="producto-card">
          <h3>Sitios Web</h3>
          <p>Diseño web moderno, responsivo y optimizado para SEO</p>
        </div>
        <div class="producto-card">
          <h3>Aplicaciones Móviles</h3>
          <p>Apps nativas y multiplataforma para iOS y Android</p>
        </div>
        <div class="producto-card">
          <h3>Software a Medida</h3>
          <p>Soluciones empresariales personalizadas para tus necesidades</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .productos-section {
    min-height: 60vh;
    padding: clamp(3rem, 8vw, 4rem) clamp(1rem, 5vw, 2rem);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  h1 {
    font-size: clamp(2.25rem, 9vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.05;
  }
  
  .producto-card:hover,
  .willing-card:hover,
  .willing-card:focus,
   .producto-card:focus
   {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .producto-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .subtitle {
    font-size: 1.125rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }
  
  .productos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: clamp(1rem, 4vw, 2rem);
  }

  .producto-card {
    padding: clamp(1.25rem, 5vw, 2rem);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }
  .willing-grid {
    display: grid;
    padding: 1rem 0;
    gap: 1rem;
  }
  
  .willing-card {
    display: grid;
    gap: 1rem;
    padding: clamp(1.25rem, 5vw, 2rem);
    border: 2px solid rgba(255, 255, 255, 0.893);
    border-radius: 0.5rem;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .willing-card img {
    width: min(100%, 22rem);
    margin-inline: auto;
  }
 @media (min-width: 768px)  {
    .willing-grid {
    display: grid;
    grid-template-columns:repeat(2, minmax(0, 1fr));
    padding: 1rem 0;
    gap: 1rem;
  }
  }
  

</style>
