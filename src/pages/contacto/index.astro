      <p>Dg. 69c Sur #78C-36</p>
      <p>Bogotá, Colombia</p>
      <a
        href="tel:+573181252775"
        class="block hover:text-paper text-gray-100 text-3xl focus:text-magenta-600 transition-colors p-2"
      >
        +57 318 1252775
      </a>
      <a
        href="mailto:hola@dinamycode.com"
