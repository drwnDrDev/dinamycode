---
// Navbar component - responsive with hamburger mobile menu
// Contact CTA button removed from top bar; appears in mobile dropdown only
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/servicios/', label: 'Servicios' },
  { href: '/productos/', label: 'Productos' },
  { href: '/contacto/', label: 'Contacto' },
  { href: 'https://businness.dinamycode.com', label: 'Businness' },

];

const isActive = (href: string) => {
  if (href.startsWith('/#')) return false;
  return currentPath === href || currentPath.startsWith(href.replace(/\/$/, '') + '/');
};
---

<nav
  id="main-nav"
  class="fixed top-0 inset-x-0 z-50 bg-ink/85 backdrop-blur-md border-b border-white/5"
  aria-label="Navegación principal"
>
  <div class="flex items-center justify-between px-6 md:px-12 py-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="DinamyCode - ir al inicio">
      <img
        src="/assets/img/dinamycode_title.svg"
        alt="DinamyCode"
        class="hidden sm:block w-auto h-9 transition-transform duration-300 group-hover:scale-110"
        width="180"
        height="36"
        loading="eager"
        decoding="async"
      />
      <img
        src="/assets/img/dc.svg"
        alt="DC"
        class="block sm:hidden w-9 h-9 rounded-full transition-transform duration-300 group-hover:scale-110"
        width="36"
        height="36"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-paper/60" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            data-astro-prefetch
            class={`nl hover:text-paper transition-colors ${isActive(href) ? 'nav-active text-paper' : ''}`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger button (mobile only) -->
    <button
      id="hamburger-btn"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Abrir menú de navegación"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-white/5 transition-colors cursor-pointer"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" role="dialog" aria-label="Menú móvil">
    <div class="border-t border-white/8 px-6 pb-6 pt-4 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          data-astro-prefetch
          class={`text-paper/70 hover:text-paper text-base font-medium py-2.5 border-b border-white/5 transition-colors flex items-center gap-2 group ${isActive(href) ? 'text-paper' : ''}`}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          <span class="w-1 h-1 rounded-full bg-dc-red opacity-0 group-hover:opacity-100 transition-opacity"></span>
          {label}
        </a>
      ))}
      <!-- CTA in mobile menu -->
      <a
        href="https://wa.me/573181252775"
        target="_blank"
        rel="noopener noreferrer"
        id="mobile-cta-btn"
        class="btn-red mt-4 bg-dc-red text-white text-sm font-semibold px-5 py-3 rounded-full text-center"
      >
        Hablemos →
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = btn.classList.toggle('open');
    menu?.classList.toggle('open', isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
  });

  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      btn?.classList.remove('open');
      menu.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Close menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) {
      btn?.classList.remove('open');
      menu?.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Add scroll shadow to nav
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('shadow-lg');
    } else {
      nav?.classList.remove('shadow-lg');
    }
  }, { passive: true });
</script>
