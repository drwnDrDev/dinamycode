---
// Footer with smart navigation - links adapt based on current page
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

// Helper: if on home page use hash links, else use absolute links with hash
const homeLink = (hash: string) => isHome ? hash : `/${hash}`;

const year = new Date().getFullYear();
---

<footer class="bg-ink pt-16 pb-8 px-6 md:px-12 border-t border-white/8">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4 group" aria-label="DinamyCode inicio">
          <img
            src="/img/dinamycode_title.png"
            alt="DinamyCode"
            class="w-auto h-10 transition-transform duration-300 group-hover:scale-110"
            width="200"
            height="40"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-paper/35 text-sm leading-relaxed max-w-xs">
          Agencia de diseño web y desarrollo de software en Bogotá, Colombia.
          Transformamos negocios con tecnología que convierte visitantes en clientes reales.
        </p>
        <!-- Social -->
        <div class="flex items-center gap-3 mt-6">
          <a
            href="https://www.linkedin.com/company/dinamycode/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn de DinamyCode"
            class="w-9 h-9 rounded-full border border-white/15 flex items-center justify-center hover:border-dc-red/60 hover:bg-dc-red/10 transition-all duration-300"
          >
            <img src="/svg/Linkedin.svg" alt="" class="w-4 h-4 opacity-55" aria-hidden="true" loading="lazy" decoding="async" />
          </a>
          <a
            href="https://wa.me/573181252775"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp de DinamyCode"
            class="w-9 h-9 rounded-full border border-white/15 flex items-center justify-center hover:border-dc-blue/60 hover:bg-dc-blue/10 transition-all duration-300"
          >
            <img src="/svg/WhatsApp.svg" alt="" class="w-4 h-4 opacity-55" aria-hidden="true" loading="lazy" decoding="async" />
          </a>
        </div>
      </div>

      <!-- Navegación inteligente -->
      <div>
        <h2 class="font-display text-paper text-lg tracking-widest mb-5">NAVEGACIÓN</h2>
        <ul class="space-y-2.5" role="list">
          <li>
            <a
              href="/servicios/"
              data-astro-prefetch
              class="text-paper/40 text-sm hover:text-paper transition-colors flex items-center gap-2 group"
            >
              <span class="w-1 h-1 rounded-full bg-dc-red opacity-0 group-hover:opacity-100 transition-opacity"></span>
              Servicios
            </a>
          </li>
          <li>
            <a
              href="/productos/"
              data-astro-prefetch
              class="text-paper/40 text-sm hover:text-paper transition-colors flex items-center gap-2 group"
            >
              <span class="w-1 h-1 rounded-full bg-dc-blue opacity-0 group-hover:opacity-100 transition-opacity"></span>
              Productos
            </a>
          </li>
          <li>
            <a
              href={homeLink('#clientes')}
              data-astro-prefetch
              class="text-paper/40 text-sm hover:text-paper transition-colors flex items-center gap-2 group"
            >
              <span class="w-1 h-1 rounded-full bg-dc-yellow opacity-0 group-hover:opacity-100 transition-opacity"></span>
              Clientes
            </a>
          </li>
          <li>
            <a
              href={homeLink('#proceso')}
              data-astro-prefetch
              class="text-paper/40 text-sm hover:text-paper transition-colors flex items-center gap-2 group"
            >
              <span class="w-1 h-1 rounded-full bg-dc-red opacity-0 group-hover:opacity-100 transition-opacity"></span>
              Proceso
            </a>
          </li>
          <li>
            <a
              href={homeLink('#nosotros')}
              data-astro-prefetch
              class="text-paper/40 text-sm hover:text-paper transition-colors flex items-center gap-2 group"
            >
              <span class="w-1 h-1 rounded-full bg-dc-blue opacity-0 group-hover:opacity-100 transition-opacity"></span>
              Nosotros
            </a>
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h2 class="font-display text-paper text-lg tracking-widest mb-5">CONTACTO</h2>
        <address class="not-italic space-y-2 text-sm text-paper/40">
          <p>Dg. 69c Sur #78C-36</p>
          <p>Bogotá, Colombia</p>
          <a href="tel:+573181252775" class="block hover:text-paper transition-colors mt-2">
            +57 318 1252775
          </a>
          <a href="mailto:hola@dinamycode.com" class="block hover:text-paper transition-colors">
            hola@dinamycode.com
          </a>
        </address>
        <!-- CTA en footer -->
        <a
          href="https://wa.me/573181252775"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-red mt-6 inline-flex items-center gap-2 bg-dc-red text-white text-xs font-semibold px-4 py-2.5 rounded-full"
        >
          Hablemos →
        </a>
      </div>

    </div>

    <div class="pt-8 border-t border-white/8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-paper/25 text-xs">DinamyCode &copy; {year} · Todos los derechos reservados.</p>
      <p class="text-paper/20 text-xs">Hecho con ♥ en Bogotá, Colombia</p>
    </div>

  </div>
</footer>

<!-- Scroll to Top button -->
<button
  id="scroll-top"
  type="button"
  aria-label="Volver al inicio de la página"
  title="Volver al inicio"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c2407e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('scroll-top');

  // Show/hide based on scroll position
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 350);
  }, { passive: true });

  // Smooth scroll to top on click
  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
