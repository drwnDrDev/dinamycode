---
import Layout from "../../layouts/Layout.astro";
import BtnAction from "../../components/UI/BtnAction.astro";

---

<Layout
  title="Servicios de Diseño Web y Desarrollo de Software | DinamyCode"
  description="Páginas web optimizadas para SEO y aplicaciones móviles a medida, chatbots inteligentes y agentes autónomos de Inteligencia Artificial"
>
  <section
    id="servicios"
    class="bg-paper dark:bg-ink relative py-24 px-6 md:px-12 overflow-hidden"
  >

    <div class="max-w-6xl mx-auto">
      <div class="reveal mb-16">
        <span
          class="inline-flex items-center gap-2 text-dc-red text-xs font-semibold tracking-[.22em] uppercase"
        >
          <span class="w-6 h-px bg-dc-red dark:text-white"></span>Lo que hacemos
        </span>
        <h2
          class="font-display text-ink mt-3 leading-none text-clamp-heading dark:text-white"
        >
          SOLUCIONES QUE TRANSFORMAN
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <!-- Diseño Web -->
        <article
          class="svc-card bg-white dark:bg-ink-card rounded-2xl p-8 border border-ink/8 reveal"
        >
          <h3
            class="font-display flex gap-2 justify-start items-center text-2xl text-ink mt-1 mb-4 tracking-wide dark:text-cyan-300"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <rect
                x="2"
                y="3"
                width="20"
                height="14"
                rx="2"
                stroke="white"
                stroke-width="2"></rect>
              <path
                d="M8 21h8M12 17v4"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            DISEÑO WEB
          </h3>
          <p class="text-ink/55 text-sm leading-relaxed dark:text-gray-300">
            Creamos <span class="font-bold">páginas web </span> personalizadas, con
            un diseño <span class="font-semibold">moderno</span> y responsivo, que
            se adaptan a cualquier dispositivo y reflejan <span
              class="font-bold text-ink-66 dark:text-gray-100"
              >la esencia de tu marca.</span
            >
          </p>
          <p class="text-ink/55 text-sm leading-relaxed dark:text-gray-200">
            Diseñamos sitios atractivos y los optimizamos para que conviertan
            visitantes en oportunidades de negocio.Tu sitio web será un
            escaparate y el <span
              class="font-bold text-ink-66 dark:text-gray-100"
              >motor de crecimiento de tu empresa</span
            > en la economia digital
          </p>
      
          <BtnAction argumeto="una pagina para mi negocio" color="text-dc-red"/>
        </article>

        <!-- Desarrollo de Apps -->
        <article
          class="svc-card bg-white rounded-2xl p-8 border border-ink/8 reveal delay-1 dark:bg-ink-card"
        >
          <h3
            class="font-display flex justify-star gap-4 items-center dark:text-dc-red text-2xl text-ink mt-1 mb-4 tracking-wide"
          >
            <svg width="20" height="24" viewBox="0 0 24 24" fill="none">
              <rect
                x="5"
                y="2"
                width="14"
                height="22"
                rx="2"
                stroke="currentColor"
                stroke-width="2"></rect>
              <circle cx="12" cy="17" r="1" fill="currentColor"></circle>
            </svg>
            DESARROLLO DE APPS
          </h3>
          <p class="text-ink/55 text-sm leading-relaxed dark:text-gray-300">
            <span class="font-bold text-ink/88 dark:text-gray-100"
              >Software</span
            > a medida. Creamos <span
              class="font-semibold text-ink/88 dark:text-gray-100"
              >aplicaciones</span
            > que automatizan procesos, mejoran el <span
              class="font-semibold text-ink/88 dark:text-gray-100"
              >control interno</span
            > y aumentan la <span
              class="font-semibold text-ink/88 dark:text-gray-100"
              >productividad</span
            > de tu <span class="font-semibold text-ink/88 dark:text-gray-100"
              >equipo.</span
            >
          </p>
          <p class="text-ink/55 text-sm leading-relaxed dark:text-gray-300">
            Nuestras soluciones no solo optimizan tu operación, también elevan
            la experiencia de tus clientes, ofreciendo rapidez, simplicidad y
            confianza en cada interacción. Con nosotros, tu app será una
            herramienta estratégica para crecer y diferenciarte en el mercado.
          </p>
       
           <BtnAction argumeto="desarrollo de apps nuevas" color="text-dc-blue"/>
        </article>

        <!-- Crecimiento Digital -->
        <article
          class="svc-card bg-white rounded-2xl p-8 border border-ink/8 dark:bg-ink-card reveal delay-2"
        >
          <h3
            class="font-display flex items-center gap-3 text-2xl text-ink mt-1 mb-4 tracking-wide dark:text-cyan-600"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path
                d="M3 17l4-4 4 4 4-5 4-4"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg> CRECIMIENTO DIGITAL
          </h3>
          <p class="text-ink/55 text-sm leading-relaxed dark:text-gray-300">
            Conectamos tu negocio con los clientes que realmente importan,
            posicionándote donde ellos te buscan y generando confianza en cada
            interacción.
          </p><p class="text-ink/55 text-sm leading-relaxed dark:text-gray-300">
            Nuestro enfoque combina creatividad y análisis de datos para que tu
            presencia digital no solo destaque, sino que se traduzca en
            resultados medibles y crecimiento sostenido
          </p>
      
          <BtnAction argumeto="implementación en mi negocio" color="text-dc-red">

    
        </article>
      </div>

      <!-- CTA -->
      <div class="reveal mt-12 text-center">
        <a
          href="https://wa.me/573181252775"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-ink text-paper bg-cyan-600 font-semibold px-8 py-4
                rounded-full hover:bg-ink/85 transition-colors duration-300 text-sm"
        >
          Cuéntanos de tu proyecto →
        </a>
      </div>
    </div>
  </section>
  <section
    id="proceso"
    class="bg-olive-100 dark:bg-ink-card relative p-10 overflow-hidden"
  >
   
    <div class="max-w-4xl mx-auto">
      <div class="reveal mb-16">
        <span
          class="inline-flex items-center gap-2 text-dc-blue text-xs font-semibold tracking-[.22em] uppercase"
        >
          <span class="w-6 h-px bg-dc-blue dark:text-cyan-200"></span>Nuestro proceso
        </span>
        <h2 class="font-display mt-2 text-ink dark:text-cyan-400 leading-none text-clamp-heading">
          ASÍ TRABAJAMOS<br />CONTIGO
        </h2>
      </div>

      <div class="space-y-2" id="accordion">
        <div
          class="tab-wrap border border-ink/12 rounded-2xl overflow-hidden reveal open"
        >
          <button
            class="w-full flex items-center gap-5 p-6 text-left hover:bg-ink/4 transition-colors"
            data-tab-trigger=""
            aria-expanded="true"
          >
            <span
              class="tab-num font-display text-5xl text-dc-red w-14 flex-shrink-0 transition-colors"
              >01</span
            >
            <h3 class="font-display dark:text-dc-red text-xl text-ink tracking-wide flex-1">
              CONSULTORÍA INICIAL
            </h3>
            <svg
              class="tab-arrow w-5 h-5 text-ink/40 dark:text-gray-500 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="tab-body">
            <p class="px-6 pb-6 text-ink/55 text-sm leading-relaxed dark:text-gray-200 pl-20">
              Analizamos tus necesidades, objetivos de negocio y el estado
              actual de tu presencia digital para construir un plan claro y
              alcanzable.
            </p>
          </div>
        </div>

        <div
          class="tab-wrap border border-ink/12 rounded-2xl overflow-hidden reveal"
        >
          <button
            class="w-full flex items-center gap-5 p-6 text-left hover:bg-ink/4 transition-colors"
            data-tab-trigger=""
            aria-expanded="false"
          >
            <span
              class="tab-num font-display dark:text-gray-500 text-5xl text-ink/25 w-14 flex-shrink-0 transition-colors"
              >02</span
            >
            <h3 class="font-display dark:text-white text-xl text-ink tracking-wide flex-1">
              DISEÑO Y DESARROLLO
            </h3>
            <svg
              class="tab-arrow w-5 h-5 text-ink/40 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="tab-body">
            <p class="px-6 pb-6 text-ink/55 dark:text-gray-300 text-sm leading-relaxed pl-20">
              Creamos tu solución a medida: visualmente atractiva, funcional y
              optimizada. Te mantenemos informado en cada etapa del proceso
              creativo.
            </p>
          </div>
        </div>

        <div
          class="tab-wrap border border-ink/12 rounded-2xl overflow-hidden reveal"
        >
          <button
            class="w-full flex items-center gap-5 p-6 text-left hover:bg-ink/4 transition-colors"
            data-tab-trigger=""
            aria-expanded="false"
          >
            <span
              class="tab-num font-display text-5xl text-ink/25 dark:text-gray-500 w-14 flex-shrink-0 transition-colors"
              >03</span
            >
            <h3 class="font-display text-xl dark:text-white text-ink tracking-wide flex-1">
              LANZAMIENTO
            </h3>
            <svg
              class="tab-arrow w-5 h-5 text-ink/40 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="tab-body">
            <p class="px-6 pb-6 text-ink/55 dark:text-gray-300 text-sm leading-relaxed pl-20">
              Desplegamos tu proyecto con las mejores prácticas de rendimiento y
              seguridad. Pruebas exhaustivas antes de salir al aire para
              garantizar cero errores.
            </p>
          </div>
        </div>

        <div
          class="tab-wrap border border-ink/12 rounded-2xl overflow-hidden reveal"
        >
          <button
            class="w-full flex items-center gap-5 p-6 text-left hover:bg-ink/4 transition-colors"
            data-tab-trigger=""
            aria-expanded="false"
          >
            <span
              class="tab-num font-display text-5xl text-ink/25 dark:text-gray-500 w-14 flex-shrink-0 transition-colors"
              >04</span
            >
            <h3 class="font-display text-xl text-ink dark:text-white tracking-wide flex-1">
              SEGUIMIENTO Y CRECIMIENTO
            </h3>
            <svg
              class="tab-arrow w-5 h-5 text-ink/40 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="tab-body">
            <p class="px-6 pb-6 text-ink/55 dark:text-gray-300 text-sm leading-relaxed pl-20">
              Monitoreamos el rendimiento y te acompañamos en el crecimiento
              continuo. Tu negocio evoluciona — tu plataforma digital también.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .servicios-section {
    min-height: 60vh;
    padding: 4rem 2rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.125rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .servicio-card {
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }

  .servicio-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .servicio-card h3 {
    font-size: clamp(1rem, 2vw, 1.5rem);
    margin-bottom: 1rem;
  }
</style>

<script>
  const tabWraps = Array.from(document.querySelectorAll(".tab-wrap"));
  const tabButtons = Array.from(document.querySelectorAll("[data-tab-trigger]"));

  const closeAllTabs = () => {
    tabWraps.forEach((wrap) => {
      wrap.classList.remove("open");
      const button = wrap.querySelector("button");
      if (button) {
        button.setAttribute("aria-expanded", "false");
      }
    });
  };

  const openTab = (button:any) => {
    const wrap = button.closest(".tab-wrap");
    if (!wrap) {
      return;
    }

    const isOpen = wrap.classList.contains("open");
    closeAllTabs();

    if (!isOpen) {
      wrap.classList.add("open");
      button.setAttribute("aria-expanded", "true");
    }
  };

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => openTab(button));
  });

  const firstButton = tabButtons[0];
  if (firstButton) {
    openTab(firstButton);
  }
</script>
